# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=origo
POSTGRES_PASSWORD=change_me_use_a_strong_password
POSTGRES_DB=origo

# ── AI Platform API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=AIza...

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_CONCURRENT_PER_PLATFORM=3

# ── Per-platform rate limits (requests / minute) ──────────────────────────────
# Paces every upstream call (monitoring AND analysis) so a run cannot burst past
# a provider's per-minute cap. Defaults below are conservative; set the real
# per-tier ceilings from your provider dashboards to pace closer to the limit
# (no redeploy needed). A value <= 0 disables limiting for that platform.
PLATFORM_RATE_LIMIT_OPENAI=500
PLATFORM_RATE_LIMIT_ANTHROPIC=500
PLATFORM_RATE_LIMIT_PERPLEXITY=50
PLATFORM_RATE_LIMIT_GEMINI=60
# Longest a single call waits for a rate-limit slot before proceeding anyway
# (fail-open safety valve; a compliant 100-prompt run's slowest call waits only
# ~1-2 windows).
PLATFORM_RATE_LIMIT_MAX_WAIT_SECONDS=300

# ── Call timeouts & dropped-call retries ──────────────────────────────────────
# Per-call ceiling for a plain (ungrounded) LLM request; one hung call must not
# stall a run.
PLATFORM_CALL_TIMEOUT_SECONDS=90
# Ceiling for WEB-GROUNDED monitoring calls (OpenAI/Anthropic run multi-round
# server-side search loops; Perplexity sonar is always grounded). Effective
# grounded timeout = max(plain, grounded).
PLATFORM_CALL_TIMEOUT_GROUNDED_SECONDS=240
# Failed/timed-out monitoring calls are re-run in up to this many extra passes
# after the first wave (0 disables). Pass N waits N × the backoff first.
MONITORING_RETRY_PASSES=2
MONITORING_RETRY_BACKOFF_SECONDS=10
# Responses whose citation-analysis call failed get this many extra passes
# before being counted as analysis drops (0 disables).
ANALYSIS_RETRY_PASSES=1

# ── Public /v1 Audit API auth ─────────────────────────────────────────────────
# Per-environment API keys for the /v1 automation surface, sent by callers as
# `X-API-Key: <key>`. Comma-separated; each entry is a bare key or `label:key`
# (the label is logged on success, never the key). Multiple keys are valid at
# once — that is the rotation path: add the new key, migrate callers, then drop
# the old one, all by editing this secret (no code change, no rebuild).
# Empty = /v1 is disabled (every request gets 401 — fail closed).
AUDIT_API_KEYS=primary:change_me_generate_a_strong_random_key
