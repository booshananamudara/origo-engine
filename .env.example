# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=origo
POSTGRES_PASSWORD=origo_dev
POSTGRES_DB=origo
# Full URL (auto-composed in docker-compose; override here for local dev outside Docker)
# DATABASE_URL=postgresql+asyncpg://origo:origo_dev@localhost:5432/origo

# ── AI Platform API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
