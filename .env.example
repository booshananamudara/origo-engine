# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=origo
POSTGRES_PASSWORD=change_me_use_a_strong_password
POSTGRES_DB=origo

# ── AI Platform API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=AIza...

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_CONCURRENT_PER_PLATFORM=3

# ── Public /v1 Audit API auth ─────────────────────────────────────────────────
# Per-environment API keys for the /v1 automation surface, sent by callers as
# `X-API-Key: <key>`. Comma-separated; each entry is a bare key or `label:key`
# (the label is logged on success, never the key). Multiple keys are valid at
# once — that is the rotation path: add the new key, migrate callers, then drop
# the old one, all by editing this secret (no code change, no rebuild).
# Empty = /v1 is disabled (every request gets 401 — fail closed).
AUDIT_API_KEYS=primary:change_me_generate_a_strong_random_key
