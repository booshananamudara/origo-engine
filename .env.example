# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_CONCURRENT_PER_PLATFORM=5

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
